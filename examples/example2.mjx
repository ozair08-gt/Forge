// MiniJavaX Example 2: Control Flow
int x = 10;

if (x > 5) {
    print(x);
}

if (x == 10) {
    print(100);
} else {
    print(0);
}

if (x >= 10) {
    print(1);
}

if (x <= 10) {
    print(2);
}

if (x != 5) {
    print(3);
}

int counter = 0;
while (counter < 5) {
    print(counter);
    counter = counter + 1;
}

int i = 0;
while (i < 3) {
    if (i == 1) {
        print(99);
    }
    print(i);
    i = i + 1;
}
